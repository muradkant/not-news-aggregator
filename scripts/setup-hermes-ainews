#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
mkdir -p .hermes

HERMES_ROOT="$PWD/.hermes"
HERMES_PROFILE_NAME="ainews"
HERMES_PROFILE_HOME="$HERMES_ROOT/profiles/$HERMES_PROFILE_NAME"

export HERMES_HOME="$HERMES_ROOT"

if hermes profile list | grep -qE "(^|[[:space:]])${HERMES_PROFILE_NAME}([[:space:]]|$)"; then
  echo "Hermes profile $HERMES_PROFILE_NAME already exists in $HERMES_ROOT"
else
  hermes profile create "$HERMES_PROFILE_NAME" --no-skills --no-alias --description "Specialized AI-news research agent for the Flutter Canvas app."
fi

mkdir -p "$HERMES_PROFILE_HOME"
touch "$HERMES_PROFILE_HOME/.no-bundled-skills"

export HERMES_HOME="$HERMES_PROFILE_HOME"
export HERMES_PROFILE="$HERMES_PROFILE_NAME"
hermes skills opt-out --remove --yes >/dev/null

config_path="$HERMES_PROFILE_HOME/config.yaml"
mkdir -p "$(dirname "$config_path")"
touch "$config_path"

if ! grep -qE '^voice:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

voice:
  auto_tts: true
  beep_enabled: false
YAML
fi

if ! grep -qE '^tts:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

tts:
  provider: kokoro
  providers:
    kokoro:
      type: command
      command: "scripts/kokoro-tts --input {input_path} --output {output_path} --voice {voice} --speed {speed}"
      output_format: wav
      voice: af_heart
YAML
fi

if ! grep -qE '^web:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

web:
  search_backend: exa
  extract_backend: exa
YAML
fi

if ! grep -qE '^memory:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

memory:
  memory_enabled: true
  user_profile_enabled: true
YAML
fi

if ! grep -qE '^skills:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

skills:
  external_dirs: []
YAML
fi

if ! grep -qE '^terminal:' "$config_path"; then
  cat >> "$config_path" <<'YAML'

terminal:
  env_passthrough:
    - AI_NEWS_SEARXNG_URL
    - AI_NEWS_SEARXNG_SEARCH_URL
    - BROWSE_CLI
YAML
fi

python - "$config_path" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")


def replace_block(content: str, name: str, block: str) -> str:
    pattern = re.compile(rf"^{name}:\n(?:^[ \t].*\n?)*", re.MULTILINE)
    replacement = block.rstrip() + "\n"
    if pattern.search(content):
        return pattern.sub(replacement, content, count=1)
    suffix = "" if content.endswith("\n") else "\n"
    return content + suffix + "\n" + replacement


text = replace_block(
    text,
    "web",
    """
web:
  search_backend: exa
  extract_backend: exa
""",
)
text = replace_block(
    text,
    "terminal",
    """
terminal:
  env_passthrough:
    - AI_NEWS_SEARXNG_URL
    - AI_NEWS_SEARXNG_SEARCH_URL
    - BROWSE_CLI
""",
)
path.write_text(text, encoding="utf-8")
PY

mkdir -p "$HERMES_PROFILE_HOME/memories"

soul_path="$HERMES_PROFILE_HOME/SOUL.md"
if [ ! -s "$soul_path" ] || grep -q "created by Nous Research" "$soul_path"; then
  cat > "$soul_path" <<'EOF'
You are the AI News Canvas research agent for this project-local Hermes profile.

Your job is to turn open-ended research requests into a living event graph: find primary sources, cross-check claims, add concise event/artifact/bridge mutations, and speak only when a short natural aside would genuinely orient the user.

For external research, use SearXNG, Exa, and Browse.sh as complementary tools when available. Use SearXNG for broad meta-search discovery and URL/snippet diversity, Exa for semantic discovery and fuller content retrieval, and Browse.sh or browser automation for dynamic, JavaScript-heavy, login-like, or extraction-hostile pages. SearXNG is configurable: choose categories, engines, language, time_range, and pageno per task instead of relying on one generic search. For AI/current-events work, consider multiple SearXNG passes across general, news, science, scientific publications, it, repos, and social media categories, then inspect unresponsive_engines and adapt. Compare results instead of trusting a single discovery path.

Prefer source quality over volume. Promote official posts, release notes, docs, papers, filings, standards pages, and original announcements. Use secondary sources to discover leads, not as the final authority when primary material is available.

Keep the Canvas stable. Extend the existing graph instead of replacing it; update existing nodes when the database already contains the relevant entity or event; add new clusters away from unrelated clusters.
EOF
fi

user_path="$HERMES_PROFILE_HOME/memories/USER.md"
if [ ! -s "$user_path" ]; then
  cat > "$user_path" <<'EOF'
§ The app operator wants compact, evidence-grounded research that enriches an existing Canvas instead of wiping it.

§ The operator values complementary discovery: SearXNG + Exa + Browse.sh should all contribute when external research is needed and available.

§ Spoken updates should be natural and sparse: say something only when it helps orientation, reports a meaningful obstacle, or briefly summarizes a useful finding.
EOF
fi

echo "Project Hermes root: $HERMES_ROOT"
echo "Project Hermes profile home: $HERMES_PROFILE_HOME"
