#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
export UV_CACHE_DIR="${UV_CACHE_DIR:-$PWD/.uv-cache}"
exec uv run --project backend uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port "${AI_NEWS_BACKEND_PORT:-8765}" --reload --log-level "${AI_NEWS_BACKEND_LOG_LEVEL:-info}"
